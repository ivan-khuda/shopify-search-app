# SmartDiscovery AI — Environment Variable Template
#
# Copy this file to `.env` and fill in real values. NEVER commit `.env`
# (it is git-ignored). This template only carries empty KEY= entries.

# Gemini API key (chat falls back gracefully if absent).
GOOGLE_GENERATIVE_AI_API_KEY=

# Postgres connection string (Prisma Accelerate URL or direct postgres://...).
DATABASE_URL=

# Shopify app credentials (from Shopify Partner Dashboard → App settings).
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
HOST=

# App handle slug from Shopify Partner Dashboard (used for post-install redirect).
SHOPIFY_APP_HANDLE=

# Same value as SHOPIFY_API_KEY; exposed to client components for App Bridge.
NEXT_PUBLIC_SHOPIFY_API_KEY=

# Vercel AI Gateway key — required for EmbeddingService.embed / embedMany. Source: Vercel Dashboard → AI Gateway → Project keys.
AI_GATEWAY_API_KEY=

# Direct postgres URL (postgresql://...) — required in production when DATABASE_URL is a Prisma Accelerate URL. Used by scripts/apply-manual-indexes.ts.
DIRECT_URL=
