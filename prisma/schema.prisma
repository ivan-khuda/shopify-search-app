// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                Int       @id @default(autoincrement())
  shop              String    // myshopify.com hostname, e.g. "example-store.myshopify.com" (D-02)
  shopifyId         BigInt?
  title             String
  handle            String
  description       String?   @db.Text
  descriptionHtml   String?   @db.Text
  vendor            String?
  productType       String?
  status            String    @default("ACTIVE") // ACTIVE, ARCHIVED, DRAFT
  tags              String[]
  publishedAt       DateTime?
  priceMin          Decimal?  @db.Decimal(10, 2)
  priceMax          Decimal?  @db.Decimal(10, 2)
  compareAtPriceMin Decimal?  @db.Decimal(10, 2)
  compareAtPriceMax Decimal?  @db.Decimal(10, 2)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  variants   ProductVariant[]
  images     ProductImage[]
  options    ProductOption[]
  embeddings ProductEmbedding[]

  @@unique([shop, id])
  @@unique([shop, shopifyId])
  @@unique([shop, handle])
  @@index([shop])
  @@index([shop, shopifyId])
  @@index([status])
  @@index([vendor])
  @@index([productType])
  @@map("products")
}

model ProductVariant {
  id                Int      @id @default(autoincrement())
  shop              String   // redundant with parent — intentional (D-04)
  productShop       String   // composite FK field 1
  productId         Int      // composite FK field 2
  shopifyId         BigInt?
  title             String
  sku               String?
  barcode           String?
  price             Decimal  @db.Decimal(10, 2)
  compareAtPrice    Decimal? @db.Decimal(10, 2)
  position          Int      @default(1)
  inventoryQuantity Int?
  inventoryPolicy   String   @default("DENY") // DENY or CONTINUE
  availableForSale  Boolean  @default(true)
  requiresShipping  Boolean  @default(true)
  taxable           Boolean  @default(true)
  weight            Decimal? @db.Decimal(10, 2)
  weightUnit        String?  // KG, LB, OZ, etc.
  option1           String?
  option2           String?
  option3           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product Product        @relation(fields: [productShop, productId], references: [shop, id], onDelete: Cascade)
  images  ProductImage[]

  @@index([shop])
  @@index([productShop, productId])
  @@index([shop, shopifyId])
  @@index([sku])
  @@index([availableForSale])
  @@map("product_variants")
}

model ProductImage {
  id          Int      @id @default(autoincrement())
  shop        String
  productShop String?  // nullable — mirrors productId Int? (D-04)
  shopifyId   BigInt?
  productId   Int?
  variantId   Int?
  url         String
  altText     String?
  width       Int?
  height      Int?
  position    Int      @default(1)
  createdAt   DateTime @default(now())

  product Product?        @relation(fields: [productShop, productId], references: [shop, id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([shop])
  @@index([productShop, productId])
  @@index([variantId])
  @@index([shop, shopifyId])
  @@map("product_images")
}

model ProductOption {
  id          Int      @id @default(autoincrement())
  shop        String   // redundant with parent — intentional (D-04)
  productShop String   // composite FK field 1
  shopifyId   BigInt?
  productId   Int      // composite FK field 2
  name        String   // e.g., "Color", "Size", "Material"
  position    Int      // 1, 2, or 3
  values      String[] // Array of option values
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productShop, productId], references: [shop, id], onDelete: Cascade)

  @@index([shop])
  @@index([productShop, productId])
  @@index([shop, shopifyId])
  @@map("product_options")
}

model ProductEmbedding {
  id          Int                    @id @default(autoincrement())
  shop        String                 // redundant with parent — intentional (D-04)
  productShop String                 // composite FK field 1
  productId   Int                    // composite FK field 2
  content     String                 @db.Text
  embedding   Unsupported("vector")? // pgvector extension - will need raw SQL for migration
  createdAt   DateTime               @default(now())

  product Product @relation(fields: [productShop, productId], references: [shop, id], onDelete: Cascade)

  @@index([shop])
  @@index([productShop, productId])
  @@map("product_embeddings")
}

model ShopifySession {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean
  scope         String?
  expires       DateTime?
  accessToken   String?
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)

  @@index([shop])
  @@index([state])
  @@map("shopify_sessions")
}
