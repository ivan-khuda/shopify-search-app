// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                Int       @id @default(autoincrement())
  shop              String // myshopify.com hostname, e.g. "example-store.myshopify.com" (D-02)
  shopifyId         BigInt?
  title             String
  handle            String
  description       String?   @db.Text
  descriptionHtml   String?   @db.Text
  vendor            String?
  productType       String?
  status            String    @default("ACTIVE") // ACTIVE, ARCHIVED, DRAFT
  tags              String[]
  publishedAt       DateTime?
  priceMin          Decimal?  @db.Decimal(10, 2)
  priceMax          Decimal?  @db.Decimal(10, 2)
  compareAtPriceMin Decimal?  @db.Decimal(10, 2)
  compareAtPriceMax Decimal?  @db.Decimal(10, 2)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  updatedAtShopify  DateTime? // Phase 2 D-17: SYN-11 conflict resolution

  variants   ProductVariant[]
  images     ProductImage[]
  options    ProductOption[]
  embeddings ProductEmbedding[]

  @@unique([shop, id])
  @@unique([shop, shopifyId])
  @@unique([shop, handle])
  @@index([shop])
  @@index([shop, shopifyId])
  @@index([status])
  @@index([vendor])
  @@index([productType])
  @@map("products")
}

model ProductVariant {
  id                Int      @id @default(autoincrement())
  shop              String // redundant with parent — intentional (D-04)
  productShop       String // composite FK field 1
  productId         Int // composite FK field 2
  shopifyId         BigInt?
  title             String
  sku               String?
  barcode           String?
  price             Decimal  @db.Decimal(10, 2)
  compareAtPrice    Decimal? @db.Decimal(10, 2)
  position          Int      @default(1)
  inventoryQuantity Int?
  inventoryPolicy   String   @default("DENY") // DENY or CONTINUE
  availableForSale  Boolean  @default(true)
  requiresShipping  Boolean  @default(true)
  taxable           Boolean  @default(true)
  weight            Decimal? @db.Decimal(10, 2)
  weightUnit        String? // KG, LB, OZ, etc.
  option1           String?
  option2           String?
  option3           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product Product        @relation(fields: [productShop, productId], references: [shop, id], onDelete: Cascade)
  images  ProductImage[]

  @@index([shop])
  @@index([productShop, productId])
  @@index([shop, shopifyId])
  @@index([sku])
  @@index([availableForSale])
  @@map("product_variants")
}

model ProductImage {
  id          Int      @id @default(autoincrement())
  shop        String
  productShop String? // nullable — mirrors productId Int? (D-04)
  shopifyId   BigInt?
  productId   Int?
  variantId   Int?
  url         String
  altText     String?
  width       Int?
  height      Int?
  position    Int      @default(1)
  createdAt   DateTime @default(now())

  product Product?        @relation(fields: [productShop, productId], references: [shop, id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([shop])
  @@index([productShop, productId])
  @@index([variantId])
  @@index([shop, shopifyId])
  @@map("product_images")
}

model ProductOption {
  id          Int      @id @default(autoincrement())
  shop        String // redundant with parent — intentional (D-04)
  productShop String // composite FK field 1
  shopifyId   BigInt?
  productId   Int // composite FK field 2
  name        String // e.g., "Color", "Size", "Material"
  position    Int // 1, 2, or 3
  values      String[] // Array of option values
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productShop, productId], references: [shop, id], onDelete: Cascade)

  @@index([shop])
  @@index([productShop, productId])
  @@index([shop, shopifyId])
  @@map("product_options")
}

model ProductEmbedding {
  id             Int                    @id @default(autoincrement())
  shop           String // redundant with parent — intentional (D-04)
  productShop    String // composite FK field 1
  productId      Int // composite FK field 2
  content        String                 @db.Text
  searchableText String                 @db.Text // D-10: exact text that was embedded; diagnostics + future re-embed detection
  modelVersion   String // EMB-03 / D-10: pinned model ID (NEVER an alias). NOT NULL — migration wipes dev rows.
  embedding      Unsupported("vector")? // pgvector extension - will need raw SQL for migration
  createdAt      DateTime               @default(now())

  product Product @relation(fields: [productShop, productId], references: [shop, id], onDelete: Cascade)

  @@unique([shop, productShop, productId]) // D-10: enables ON CONFLICT in EmbeddingService.embedAndStore upsert
  @@index([shop])
  @@index([productShop, productId])
  @@map("product_embeddings")
}

model ShopifySession {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean
  scope         String?
  expires       DateTime?
  accessToken   String?
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)

  @@index([shop])
  @@index([state])
  @@map("shopify_sessions")
}

// Phase 2 additions — D-03, D-07, D-17.

enum SyncState {
  queued
  running
  succeeded
  failed
  partial
}

model SyncRun {
  id             String    @id @default(cuid())
  shop           String
  state          SyncState @default(queued)
  processedCount Int       @default(0)
  totalCount     Int?
  errors         String[]  @default([])
  cursor         String?
  idempotencyKey String    @unique
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?

  @@index([shop])
  @@map("sync_runs")
}

model WebhookEvent {
  eventId    String   @id
  shop       String
  topic      String
  receivedAt DateTime @default(now())

  @@index([shop])
  @@map("webhook_events")
}

model Conversation {
  id            String   @id @default(cuid())
  shop          String
  visitorId     String
  customerId    String?
  title         String   @db.VarChar(60)
  messages      Json     @default("[]")
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([shop])
  @@index([shop, visitorId, lastMessageAt(sort: Desc)])
  @@index([shop, customerId, lastMessageAt(sort: Desc)])
  @@index([lastMessageAt])
  @@map("conversations")
}

model SavedProduct {
  // Partial unique indexes live in db/manual-indexes.sql (D-20)
  id         String   @id @default(cuid())
  shop       String
  visitorId  String
  customerId String?
  productId  String
  savedAt    DateTime @default(now())

  @@index([shop])
  @@index([shop, visitorId])
  @@index([shop, customerId])
  @@map("saved_products")
}

model VisitorCustomerLink {
  shop       String
  visitorId  String
  customerId String
  mergedAt   DateTime @default(now())

  @@id([shop, visitorId, customerId])
  @@index([shop, visitorId])
  @@index([shop, customerId])
  @@map("visitor_customer_links")
}

// Phase 7 D-10: per-shop active chat model selection.
// Empty by design (D-09) — getActiveChatModel falls back to DEFAULT_MODEL
// when no row exists. First /settings Save creates the row.
model ShopSettings {
  shop              String   @id
  activeChatModelId String
  updatedAt         DateTime @updatedAt

  @@map("shop_settings")
}
