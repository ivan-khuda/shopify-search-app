// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                Int       @id @default(autoincrement())
  shopifyId         BigInt?   @unique
  title             String
  handle            String    @unique
  description       String?   @db.Text
  descriptionHtml   String?   @db.Text
  vendor            String?
  productType       String?
  status            String    @default("ACTIVE") // ACTIVE, ARCHIVED, DRAFT
  tags              String[]
  publishedAt       DateTime?
  priceMin          Decimal?  @db.Decimal(10, 2)
  priceMax          Decimal?  @db.Decimal(10, 2)
  compareAtPriceMin Decimal?  @db.Decimal(10, 2)
  compareAtPriceMax Decimal?  @db.Decimal(10, 2)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  variants   ProductVariant[]
  images     ProductImage[]
  options    ProductOption[]
  embeddings ProductEmbedding[]

  @@index([shopifyId])
  @@index([handle])
  @@index([status])
  @@index([vendor])
  @@index([productType])
  @@map("products")
}

model ProductVariant {
  id                Int      @id @default(autoincrement())
  shopifyId         BigInt?  @unique
  productId         Int
  title             String
  sku               String?
  barcode           String?
  price             Decimal  @db.Decimal(10, 2)
  compareAtPrice    Decimal? @db.Decimal(10, 2)
  position          Int      @default(1)
  inventoryQuantity Int?
  inventoryPolicy   String   @default("DENY") // DENY or CONTINUE
  availableForSale  Boolean  @default(true)
  requiresShipping  Boolean  @default(true)
  taxable           Boolean  @default(true)
  weight            Decimal? @db.Decimal(10, 2)
  weightUnit        String? // KG, LB, OZ, etc.
  option1           String?
  option2           String?
  option3           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  images  ProductImage[]

  @@index([shopifyId])
  @@index([productId])
  @@index([sku])
  @@index([availableForSale])
  @@map("product_variants")
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  shopifyId BigInt?  @unique
  productId Int?
  variantId Int?
  url       String
  altText   String?
  width     Int?
  height    Int?
  position  Int      @default(1)
  createdAt DateTime @default(now())

  product Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([variantId])
  @@index([shopifyId])
  @@map("product_images")
}

model ProductOption {
  id        Int      @id @default(autoincrement())
  shopifyId BigInt?  @unique
  productId Int
  name      String // e.g., "Color", "Size", "Material"
  position  Int // 1, 2, or 3
  values    String[] // Array of option values
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([shopifyId])
  @@map("product_options")
}

model ProductEmbedding {
  id        Int                    @id @default(autoincrement())
  productId Int
  content   String                 @db.Text
  embedding Unsupported("vector")? // pgvector extension - will need raw SQL for migration
  createdAt DateTime               @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_embeddings")
}

model ShopifySession {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean
  scope         String?
  expires       DateTime?
  accessToken   String?
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)

  @@index([shop])
  @@index([state])
  @@map("shopify_sessions")
}
